{
  "name": "@bacca2095/webphone",
  "version": "1.1.0",
  "type": "module",
  "description": "A Vue 3 webphone component library",
  "keywords": [
    "vue",
    "vue3",
    "webphone",
    "sip",
    "webrtc",
    "jssip",
    "voip",
    "component",
    "library"
  ],
  "homepage": "https://bacca2095.github.io/webphone",
  "bugs": {
    "url": "https://github.com/Bacca2095/webphone/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bacca2095/webphone"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./webcomponent": {
      "import": "./dist/webphone.es.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:wc": "vite build --config vite.wc.config.ts",
    "build:all": "run-s build build:wc",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/vue": "^1.17.0",
    "@vueuse/core": "14.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jssip": "3.13.8",
    "reka-ui": "2.9.9",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@semantic-release/github": "^12.0.8",
    "@tailwindcss/vite": "4.3.0",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.3",
    "@types/node": "24.12.4",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/eslint-plugin": "1.6.17",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.60.0",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "pinia": "3.0.4",
    "semantic-release": "^25.0.3",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-dts": "5.0.1",
    "vite-plugin-vue-devtools": "8.1.2",
    "vitest": "4.1.7",
    "vue": "3.5.34",
    "vue-tsc": "3.3.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
